<Window x:Class="FileScannerApp.Wpf.ScanResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scan results"
        Height="520"
        Width="760"
        WindowStartupLocation="CenterOwner">
    <Border Margin="18" Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="ResultsGrid"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      LoadingRow="ResultsGrid_LoadingRow" />

            <StackPanel Grid.Row="1" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="Close_Click">Close</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
