<Window x:Class="FileScannerApp.Wpf.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="History"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterOwner">
    <Border Margin="18" Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl>
                <TabItem Header="Scans">
                    <TreeView x:Name="ScansTreeView" Margin="12" />
                </TabItem>
                <TabItem Header="Operations">
                    <TreeView x:Name="OperationsTreeView" Margin="12" SelectedItemChanged="OperationsTreeView_SelectedItemChanged" />
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="1" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="UndoButton" Click="Undo_Click">Undo selected</Button>
                <Button Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="Close_Click">Close</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
