<Window x:Class="FileScannerApp.Wpf.OrganizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Organize files"
        Height="560"
        Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Margin="18" Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="22" FontWeight="Bold" Text="Organize files" />

            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Source" />
                <TextBox x:Name="SourceTextBox" Grid.Column="1" Height="38" IsReadOnly="True" VerticalContentAlignment="Center" />
                <Button Grid.Column="2" Margin="12,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseSource_Click">Browse</Button>
            </Grid>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Destination" />
                <TextBox x:Name="DestinationTextBox" Grid.Column="1" Height="38" IsReadOnly="True" VerticalContentAlignment="Center" />
                <Button Grid.Column="2" Margin="12,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseDestination_Click">Browse</Button>
            </Grid>

            <GroupBox Grid.Row="3" Margin="0,20,0,0" Header="Operation">
                <StackPanel Margin="12" Orientation="Horizontal">
                    <RadioButton x:Name="MoveRadioButton" IsChecked="True" Content="Move files" />
                    <RadioButton x:Name="CopyRadioButton" Margin="20,0,0,0" Content="Copy files" />
                </StackPanel>
            </GroupBox>

            <Grid Grid.Row="4" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="File groups">
                    <UniformGrid Margin="12" Columns="2">
                        <CheckBox x:Name="ExecutablesCheckBox" Margin="0,0,0,10" Content="Executables" />
                        <CheckBox x:Name="DocumentsCheckBox" Margin="0,0,0,10" Content="Documents" />
                        <CheckBox x:Name="ImagesCheckBox" Margin="0,0,0,10" Content="Images" />
                        <CheckBox x:Name="VideosCheckBox" Margin="0,0,0,10" Content="Videos" />
                    </UniformGrid>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="Options">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="CreateSubfoldersCheckBox" Margin="0,0,0,10" Content="Create subfolders by type" />
                        <CheckBox x:Name="OverwriteExistingCheckBox" Content="Overwrite existing files" />
                    </StackPanel>
                </GroupBox>
            </Grid>

            <StackPanel Grid.Row="5" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click">Cancel</Button>
                <Button Margin="8,0,0,0" Click="Organize_Click">Organize</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
