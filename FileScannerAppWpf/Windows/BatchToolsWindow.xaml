<Window x:Class="FileScannerApp.Wpf.BatchTools"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch tools"
        Height="820"
        Width="1180"
        MinHeight="760"
        MinWidth="1080"
        WindowStartupLocation="CenterOwner">

    <Border Margin="18" Style="{StaticResource PanelBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="24" FontWeight="Bold" Text="Batch tools" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           Text="Organize files and prepare batch renaming from one screen." />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Text="Folder" />

                <TextBox x:Name="FolderTextBox"
                         Grid.Column="1"
                         Height="38"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />

                <Button Grid.Column="2"
                        Margin="12,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="Browse_Click">
                    Browse
                </Button>
            </Grid>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Organize files">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center" Text="Destination" />
                            <TextBox x:Name="DestinationTextBox"
                                     Grid.Column="1"
                                     Height="38"
                                     IsReadOnly="True"
                                     VerticalContentAlignment="Center" />
                            <Button Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BrowseDestination_Click">
                                Browse
                            </Button>
                        </Grid>

                        <GroupBox Grid.Row="1" Margin="0,16,0,0" Header="Operation">
                            <StackPanel Margin="12" Orientation="Horizontal">
                                <RadioButton x:Name="MoveRadioButton" IsChecked="True" Content="Move files" />
                                <RadioButton x:Name="CopyRadioButton" Margin="20,0,0,0" Content="Copy files" />
                            </StackPanel>
                        </GroupBox>

                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="File groups">
                                <UniformGrid Margin="12" Columns="2">
                                    <CheckBox x:Name="ExecutablesCheckBox" Margin="0,0,0,10" Content="Executables" />
                                    <CheckBox x:Name="DocumentsCheckBox" Margin="0,0,0,10" Content="Documents" />
                                    <CheckBox x:Name="ImagesCheckBox" Margin="0,0,0,10" Content="Images" />
                                    <CheckBox x:Name="VideosCheckBox" Margin="0,0,0,10" Content="Videos" />
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="Options">
                                <StackPanel Margin="12">
                                    <CheckBox x:Name="CreateSubfoldersCheckBox" Margin="0,0,0,10" Content="Create subfolders by type" />
                                    <CheckBox x:Name="OverwriteExistingCheckBox" Content="Overwrite existing files" />
                                </StackPanel>
                            </GroupBox>
                        </Grid>

                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="Batch rename">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox x:Name="PatternTextBox"
                                 Height="38"
                                 TextChanged="PatternTextBox_TextChanged"
                                 ToolTip="Example: {name}_{counter}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,8"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="Use tokens like {name}, {created}, {modified}, {counter}, {folder}, {ext}." />

                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <RadioButton x:Name="NoneRadioButton"
                                         IsChecked="True"
                                         Content="Keep case"
                                         Checked="CaseOption_Checked" />
                            <RadioButton x:Name="UpperRadioButton"
                                         Margin="16,0,0,0"
                                         Content="UPPERCASE"
                                         Checked="CaseOption_Checked" />
                            <RadioButton x:Name="LowerRadioButton"
                                         Margin="16,0,0,0"
                                         Content="lowercase"
                                         Checked="CaseOption_Checked" />
                            <RadioButton x:Name="CapitalizeRadioButton"
                                         Margin="16,0,0,0"
                                         Content="Capitalize"
                                         Checked="CaseOption_Checked" />
                        </StackPanel>

                        <GroupBox Grid.Row="3" Margin="0,16,0,0" Header="Tokens">
                            <ListBox x:Name="TokensListBox"
                                     Margin="12"
                                     MouseDoubleClick="TokensListBox_MouseDoubleClick">
                                <ListBoxItem ToolTip="Original file name (without extension)">{name}</ListBoxItem>
                                <ListBoxItem ToolTip="File creation date">{created}</ListBoxItem>
                                <ListBoxItem ToolTip="File last modified date">{modified}</ListBoxItem>
                                <ListBoxItem ToolTip="Incremental number, e.g. 001">{counter}</ListBoxItem>
                                <ListBoxItem ToolTip="Folder name">{folder}</ListBoxItem>
                                <ListBoxItem ToolTip="File extension (without dot)">{ext}</ListBoxItem>
                            </ListBox>
                        </GroupBox>
                    </Grid>
                </GroupBox>
            </Grid>

            <DataGrid x:Name="PreviewGrid"
                      Grid.Row="3"
                      Margin="0,20,0,0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="30"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      FontSize="13">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="8,5"/>
                    </Style>

                    <Style TargetType="DataGridRow">
                        <Setter Property="MinHeight" Value="30"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,4"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Current name" Binding="{Binding NameBefore}" Width="*" />
                    <DataGridTextColumn Header="New name" Binding="{Binding NameAfter}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="4"
                        Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Click="Cancel_Click">
                    Cancel
                </Button>

                <Button Margin="8,0,0,0"
                        Click="ApplyChanges_Click">
                    Apply changes
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
